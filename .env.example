# ============================================================
# AstroNova Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ────────────────────────────────────────────────────────────
# PostgreSQL / TimescaleDB
# ────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=astronova
POSTGRES_USER=astronova
POSTGRES_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql+asyncpg://astronova:changeme@localhost:5432/astronova

# TimescaleDB (runs on the same postgres instance)
TIMESCALE_ENABLED=true

# ────────────────────────────────────────────────────────────
# Redis
# ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ────────────────────────────────────────────────────────────
# Apache Kafka
# ────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_DATA=astronova.raw.solexs
KAFKA_TOPIC_PROCESSED=astronova.processed
KAFKA_TOPIC_FEATURES=astronova.features
KAFKA_TOPIC_ALERTS=astronova.alerts
KAFKA_CONSUMER_GROUP=astronova-consumers

# ────────────────────────────────────────────────────────────
# JWT Security
# ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ────────────────────────────────────────────────────────────
# MLflow
# ────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=astronova-forecasting
MLFLOW_MODEL_REGISTRY_URI=http://localhost:5000

# ────────────────────────────────────────────────────────────
# ChromaDB (Vector Store for RAG)
# ────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_FLARE_EVENTS=flare_events
CHROMA_COLLECTION_KNOWLEDGE=space_weather_knowledge

# ────────────────────────────────────────────────────────────
# Ollama (Local LLM)
# ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ────────────────────────────────────────────────────────────
# Internal Service URLs (used by gateway and cross-service calls)
# ────────────────────────────────────────────────────────────
INGESTION_SERVICE_URL=http://ingestion:8001
PROCESSING_SERVICE_URL=http://processing:8002
FEATURES_SERVICE_URL=http://features:8003
FORECASTING_SERVICE_URL=http://forecasting:8004
XAI_SERVICE_URL=http://xai:8005
EARTH_IMPACT_SERVICE_URL=http://earth-impact:8006
SATELLITE_RISK_SERVICE_URL=http://satellite-risk:8007
RAG_SERVICE_URL=http://rag:8008
COPILOT_SERVICE_URL=http://copilot:8009
NOTIFICATION_SERVICE_URL=http://notifications:8010
GATEWAY_URL=http://gateway:8000

# ────────────────────────────────────────────────────────────
# SMTP / Notifications
# ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_RECIPIENTS=admin@isro.gov.in
WEBHOOK_URL=

# ────────────────────────────────────────────────────────────
# Application Config
# ────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=100

# ────────────────────────────────────────────────────────────
# Data Paths (inside Docker containers)
# ────────────────────────────────────────────────────────────
DATA_DIR=/app/data
MODEL_DIR=/app/models
LOG_DIR=/app/logs

# ────────────────────────────────────────────────────────────
# APScheduler Cron Schedules
# ────────────────────────────────────────────────────────────
INGESTION_CRON=*/5 * * * *
RETRAINING_CRON=0 2 * * 0
